# ═══════════════════════════════════════════
# FakeBuster AI — Environment Configuration
# ═══════════════════════════════════════════
# Copy this to .env and fill in your values

# ── Database ──
DATABASE_URL=postgresql+asyncpg://fakebuster:fakebuster_secret@db:5432/fakebuster
DATABASE_URL_SYNC=postgresql://fakebuster:fakebuster_secret@db:5432/fakebuster

# ── Redis ──
REDIS_URL=redis://redis:6379/0

# ── JWT Auth ──
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60

# ── ClamAV ──
CLAMAV_HOST=clamav
CLAMAV_PORT=3310

# ── Upload Limits ──
MAX_UPLOAD_SIZE_MB=50

# ── Rate Limiting ──
RATE_LIMIT_REQUESTS=30
RATE_LIMIT_WINDOW_SECONDS=60

# ── App ──
APP_ENV=development
DEBUG=true
MEDIA_STORAGE_PATH=/app/media
